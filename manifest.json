{
  "manifest_version": 3,
  "name": "Chat History Cleaner",
  "version": "1.1.2",
  "version_name": "1.1.2 - 2025-01-28 17:25",
  "description": "Скрывает предыдущие блоки сообщений для снижения нагрузки на компьютер",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
